# ============================================================
# Royal Joias — variáveis de ambiente
# Copie este arquivo para `.env` (dev) e configure os mesmos
# valores no painel do host (Vercel → Settings → Environment
# Variables). NUNCA commite `.env` com valores reais.
# ============================================================

# ---- Supabase (obrigatório) --------------------------------
# URL do seu projeto Supabase (formato: https://<ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Chave pública (publishable / anon). Segura para exposição no client.
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ID do projeto (aparece no dashboard do Supabase)
SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ---- Supabase server-only (NUNCA prefixar com VITE_) -------
# Chave service_role — bypass de RLS. Use apenas em server functions
# e edge routes. NÃO exponha no client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Ambiente ---------------------------------------------
NODE_ENV=production

# ---- CI opcional (checagem de grants) ---------------------
# Usado por scripts/check-supabase-grants.mjs no pipeline.
# Reaproveita SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY acima.
